{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Url": "http://localhost:8080"
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "chatbot-api",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "chatbot-api": {
        "Destinations": {
          "primary": {
            "Address": "https+http://chatbot-api"
          }
        }
      }
    }
  }
}
